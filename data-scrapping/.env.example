# Environment Variables Template
# ================================
# Copy file ini jadi .env, lalu isi nilai aslinya.
# JANGAN push file .env ke GitHub (sudah di .gitignore).

# YouTube Data API v3 key
# Dapatkan di: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# pyngrok authtoken (untuk Streamlit FE di Colab)
# Dapatkan di: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken_here